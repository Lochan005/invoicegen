# Copy to .env.local for local development only.
# Run FastAPI (uvicorn) on this origin; `next dev` proxies /invoice-api/* to it.
# Restart `npm run dev` after changing this file.
# Do NOT add BACKEND_PROXY_URL to Vercel — production uses vercel.json → Python (no proxy).
BACKEND_PROXY_URL=http://127.0.0.1:8000
